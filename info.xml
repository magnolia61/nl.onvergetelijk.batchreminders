<?xml version="1.0"?>
<extension key="nl.onvergetelijk.batchreminders" type="module">
  <file>batchreminders</file>
  <name>Onvergetelijk - Batchreminders</name>
  <description>Batchgewijze verzending van CiviCRM Scheduled Reminders.</description>
  <license>AGPL-3.0</license>
  <authors>
    <author>
      <name>magnolia61</name>
      <email>richard.van.oosterhout@gmail.com</email>
      <role>Maintainer</role>
    </author>
  </authors>
  <urls>
    <url desc="Main Extension Page">https://www.onvergetelijk.nl</url>
    <url desc="Documentation">https://www.onvergetelijk.nl</url>
    <url desc="Support">https://www.onvergetelijk.nl</url>
    <url desc="Licensing">https://www.gnu.org/licenses/agpl-3.0.html</url>
  </urls>
  <releaseDate>2026-05-14</releaseDate>
  <version>3.0.0</version>
  <develStage>stable</develStage>
  <compatibility>
    <ver>6.14</ver>
  </compatibility>
  <comments>Pure logging hook, de daadwerkelijke batch-limiet wordt door het externe bash-script afgehandeld.</comments>
  <requires>
    <ext>nl.onvergetelijk.base</ext>
  </requires>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/Batchreminders</namespace>
    <format>25.01.1</format>
    <angularModule>crmBatchreminders</angularModule>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
</extension>